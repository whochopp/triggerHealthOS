# Airtable Configuration
REACT_APP_AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
REACT_APP_AIRTABLE_API_KEY=keyXXXXXXXXXXXXXX

# Zapier Webhook URLs
REACT_APP_ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/
REACT_APP_WEBHOOK_SECRET=your-webhook-secret-key

# Individual Trigger Webhooks
REACT_APP_ZAPIER_NEWCLIENT_WEBHOOK=https://hooks.zapier.com/hooks/catch/xxxxx/newclient
REACT_APP_ZAPIER_FORMRECEIVED_WEBHOOK=https://hooks.zapier.com/hooks/catch/xxxxx/formreceived
REACT_APP_ZAPIER_ASSIGNCLIENT_WEBHOOK=https://hooks.zapier.com/hooks/catch/xxxxx/assignclient
REACT_APP_ZAPIER_NOSHOW_WEBHOOK=https://hooks.zapier.com/hooks/catch/xxxxx/noshow
REACT_APP_ZAPIER_REMINDFORM_WEBHOOK=https://hooks.zapier.com/hooks/catch/xxxxx/remindform
REACT_APP_ZAPIER_LOGSESSION_WEBHOOK=https://hooks.zapier.com/hooks/catch/xxxxx/logsession
REACT_APP_ZAPIER_NEEDSFEEDBACK_WEBHOOK=https://hooks.zapier.com/hooks/catch/xxxxx/needsfeedback
REACT_APP_ZAPIER_LATEFOLLOWUP_WEBHOOK=https://hooks.zapier.com/hooks/catch/xxxxx/latefollowup
REACT_APP_ZAPIER_SENDFEEDBACK_WEBHOOK=https://hooks.zapier.com/hooks/catch/xxxxx/sendfeedback
REACT_APP_ZAPIER_CHECKPROGRESS_WEBHOOK=https://hooks.zapier.com/hooks/catch/xxxxx/checkprogress
REACT_APP_ZAPIER_SYNCGPT_WEBHOOK=https://hooks.zapier.com/hooks/catch/xxxxx/syncgpt

# GPT-4 Configuration (Optional)
REACT_APP_OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxx

# Any.do Configuration (Optional)
REACT_APP_ANYDO_API_KEY=your-anydo-api-key